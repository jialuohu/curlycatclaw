# Development overrides for curlycatclaw.
# Copy this file to docker-compose.override.yml to build from source:
#   cp docker-compose.override.yml.example docker-compose.override.yml
#
# Docker Compose auto-merges override files. No flags needed:
#   docker compose up -d    (builds from source when override is present)
#
# To enable Ollama and/or the updater sidecar, create .env next to docker-compose.yml:
#   echo "COMPOSE_PROFILES=ollama,updater" > .env
#   docker compose up -d    (reads .env automatically)
services:
  curlycatclaw:
    build: .

  curlycatclaw-updater:
    build:
      context: .
      dockerfile: Dockerfile.updater
    environment:
      - BUILD_MODE=true
