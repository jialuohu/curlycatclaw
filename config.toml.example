timezone = "America/Los_Angeles"

[claude]
api_key = "sk-ant-..."
model   = "claude-sonnet-4-6-20250514"

[telegram]
token = "123456:ABC-DEF..."
# Restrict to specific Telegram user IDs. Required unless allow_all = true.
allowed_user_ids = []
# Set to true to allow any Telegram user to interact with this bot.
# allow_all = true
# Show tool calls to the user in Telegram (default: true).
# show_tool_calls = true

[storage]
# WARNING: ~ does not expand in TOML values; use an absolute path.
# db_path = "~/.curlycatclaw/curlycatclaw.db"
db_path = "/home/you/.curlycatclaw/curlycatclaw.db"
# Docker: use "/data/curlycatclaw.db" (the /data volume is mounted by docker-compose).

# MCP server configurations
[[mcp.servers]]
name    = "search"
command = "npx"
args    = ["-y", "@anthropic/mcp-server-brave-search"]
[mcp.servers.env]
BRAVE_API_KEY = "encrypted:ref:brave_api_key"

# Prompt budget manager (uses Claude Haiku to classify context relevance)
# [budget]
# enabled = true
# model   = "claude-haiku-4-5-20251001"

# Vector search via Qdrant (requires Qdrant server running)
# Bare metal: docker run -p 6333:6333 -p 6334:6334 qdrant/qdrant
# Docker Compose: Qdrant starts automatically; use qdrant_addr = "qdrant:6334"
# [vector]
# enabled     = true
# qdrant_addr = "localhost:6334"
#
# Embedding provider: "fnv" (default, offline), "ollama" (free, local), "voyage" (paid, best)
# embedder = "fnv"
#
# Ollama settings (when embedder = "ollama")
# ollama_url   = "http://localhost:11434"
# ollama_model = "nomic-embed-text"
# ollama_dim   = 768
#
# Voyage AI settings (when embedder = "voyage")
# voyage_api_key = "pa-..."
# voyage_model   = "voyage-3-lite"
# voyage_dim     = 512

# Hierarchical memory (persistent user facts + conversation summaries)
# [memory]
# enabled = true
# max_facts = 50                    # Max user facts per user
# summary_relevance_limit = 3       # Max relevant summaries to retrieve per message
# summary_score_threshold = 0.3     # Min similarity score to include a summary
# summarize_model = ""              # Model for summarization (default: same as claude.model)
# min_messages_to_summarize = 4     # Skip summarization for very short conversations

# WebAssembly skill plugins
# [wasm]
# enabled    = true
# skills_dir = "/home/you/.curlycatclaw/skills"

# Logging configuration
# [logging]
# level = "info"          # debug, info, warn, error
# file = "/var/log/curlycatclaw/curlycatclaw.log"
# max_size = 50           # MB per file before rotation
# max_age = 14            # days to keep old files
# max_backups = 3         # number of old files to keep
# format = "text"         # text or json

# Health check HTTP endpoint (for Docker/monitoring)
# [health]
# enabled = true
# port = 8080

# Tool confirmation: tool name prefixes that require user confirmation before executing.
# confirm_tools = ["cancel_reminder", "filesystem__delete"]

# Filesystem sandbox (Linux only, requires kernel 5.13+)
# [sandbox]
# enabled = false
# extra_paths = ["/usr/share/ca-certificates"]       # additional read-only paths
# extra_paths_rw = ["/var/lib/curlycatclaw/custom"]  # additional read-write paths
