timezone = "America/Los_Angeles"

[claude]
# Choose ONE authentication method:
#
# Option 1: CLI subprocess mode (Claude subscription, recommended).
# Run `claude setup-token` to get a long-lived OAuth token.
# cli_path    = "/usr/local/bin/claude"
# oauth_token = "sk-ant-oat01-..."
#
# Option 2: Direct API with API key (separate billing).
# api_key  = "sk-ant-..."
#
model = "claude-opus-4-6"
# Reasoning depth: low/medium = standard reasoning, high/xhigh/max = extended thinking enabled (xhigh requires Claude Opus 4.7+).
# Override per session with /effort in Telegram, or env CURLYCATCLAW_THINKING_EFFORT.
# thinking_effort = "high"
# isolated_home = "/data/claude-home"

[telegram]
token = "123456:ABC-DEF..."
allowed_user_ids = []
# allow_all = true
# show_tool_calls = true

[storage]
db_path = "/data/curlycatclaw.db"

# --- Optional features below. Everything works without these. ---

# Vector search via Qdrant + Ollama (semantic memory).
# Docker Compose starts both Qdrant and Ollama automatically.
# Bare metal: docker run -p 6333:6333 -p 6334:6334 qdrant/qdrant
# First run: ollama pull bge-m3
# [vector]
# enabled     = true
# qdrant_addr = "localhost:6334"
# embedder    = "ollama"              # "ollama" (default), "voyage" (paid), "fnv" (offline)
# ollama_url   = "http://localhost:11434"
# ollama_model = "bge-m3"
# ollama_dim   = 1024
# voyage_api_key = "pa-..."          # only if embedder = "voyage"
# voyage_model   = "voyage-3-lite"
# voyage_dim     = 512
#
# Env overrides: CURLYCATCLAW_EMBEDDER, CURLYCATCLAW_OLLAMA_URL

# Hierarchical memory (user facts + conversation summaries).
# Requires [vector] to be enabled for summary search.
# [memory]
# enabled = true
# max_facts = 50
# summary_relevance_limit = 3
# summary_score_threshold = 0.3
# min_messages_to_summarize = 4
# vector_search_timeout_seconds = 5

# Observation memory (auto-extraction from conversations).
# [memory.observations]
# enabled = true
# extraction_interval = 3     # extract every N turns
# supersession_threshold = 0.8 # confidence threshold for auto-filtering superseded observations
# hybrid_search = false        # combine vector + FTS5 keyword search
# progressive_retrieval = false # 3-layer display (compact index + expanded + on-demand)

# MCP servers for extra tools.
# [[mcp.servers]]
# name    = "search"
# command = "npx"
# args    = ["-y", "@anthropic/mcp-server-brave-search"]
# [mcp.servers.env]
# BRAVE_API_KEY = "your-brave-api-key"

# Google Workspace via gws CLI (https://github.com/googleworkspace/cli).
#
# Auth uses an OAuth browser consent flow. On headless servers, do the
# browser step on your laptop and copy the credentials over:
#
#   ON YOUR LAPTOP (needs Node.js + browser):
#     npm install -g @googleworkspace/cli
#     gws auth login -s drive,gmail,calendar,sheets,docs,tasks
#     gws auth export --unmasked > gws-credentials.json
#
#   THEN transfer gws-credentials.json to this server and place at
#   ~/.curlycatclaw/gws-credentials.json (chmod 600).
#
#   DO NOT run `gws auth login` on a headless server — it will hang.
# [[mcp.servers]]
# name    = "gws"
# command = "curlycatclaw-gws-mcp"
# [mcp.servers.env]
# GWS_PATH = "gws"
# GOOGLE_WORKSPACE_CLI_CREDENTIALS_FILE = "/data/gws-credentials.json"  # Docker path (mounted from ~/.curlycatclaw)
# GWS_SKILLS_DIR = ""           # optional: pre-generated skills dir (skip gws generate-skills)
# GWS_FILTER = "gmail_*,calendar_*,drive_*,sheets_*,docs_*,slides_*,tasks_*"  # optional: glob filter
#
# Multi-account: on your laptop, authenticate each account separately and
# export to separate files:
#   gws auth login -s drive,gmail,calendar   # log in with account #2
#   gws auth export --unmasked > gws-work-credentials.json
# Then transfer each file to the server under ~/.curlycatclaw/.
# Then replace GOOGLE_WORKSPACE_CLI_CREDENTIALS_FILE with GWS_ACCOUNT_* vars:
# GWS_ACCOUNT_PERSONAL          = "/data/gws-credentials.json"
# GWS_ACCOUNT_PERSONAL_SERVICES = "gmail,calendar,drive,sheets,docs,slides,tasks"
# GWS_ACCOUNT_WORK              = "/data/gws-work-credentials.json"
# GWS_ACCOUNT_WORK_SERVICES     = "gmail"  # omit to allow all services
# GWS_DEFAULT_ACCOUNT           = "personal"

# GitHub via github-mcp-server (https://github.com/github/github-mcp-server).
# Auth: create a Personal Access Token at https://github.com/settings/tokens
# with scopes: repo, read:org, read:packages (minimum for dev workflows).
#
# Default is --read-only (safe: browse repos, read issues/PRs, check CI).
# To enable issue creation from Telegram (capture_diagnostics + create_issue):
#   1. Remove --read-only from args below
#   2. Ensure your PAT has "repo" scope
#   3. Create labels on your repo: gh label create bug && gh label create enhancement && gh label create alpha
#   4. Set [github] owner/repo below
# [[mcp.servers]]
# name    = "github"
# command = "github-mcp-server"
# args    = ["stdio", "--toolsets", "repos,issues,pull_requests,actions,users", "--read-only"]
# [mcp.servers.env]
# GITHUB_PERSONAL_ACCESS_TOKEN = "ghp_..."

# Google Maps via remote Streamable HTTP MCP (experimental — Google public preview).
# Auth: create a Google Maps Platform API key at
# https://console.cloud.google.com/google/maps-apis/credentials
# Enable: Places API (New), Routes API, Geocoding API.
# Free tier: $200/month credit (~28,000 place searches).
# [[mcp.servers]]
# name      = "google-maps"
# transport = "http"
# url       = "https://mapstools.googleapis.com/mcp"
# [mcp.servers.headers]
# X-Goog-Api-Key = "your-google-maps-api-key"

# GitHub issue creation settings. Used by capture_diagnostics + system prompt
# to create issues from Telegram conversations. Only needed if write mode is enabled.
# [github]
# owner = "jialuohu"
# repo  = "curlycatclaw"

# Health check endpoint (Docker/monitoring). Enabled by default.
[health]
enabled = true
port    = 18080

# Projects for CLI work (/project command).
# [[projects]]
# name = "myapp"
# path = "/data/projects/myapp"

# Logging.
# [logging]
# level = "info"
# file = "/var/log/curlycatclaw/curlycatclaw.log"
# format = "text"

# External skill collections.
# [[skill_collections]]
# path = "/data/skills/my-tools"

# Wasm plugins.
# [wasm]
# enabled    = true
# skills_dir = "/data/skills"

# Voice transcription via OpenAI Whisper (speech-to-text).
# [voice]
# enabled = false
# openai_api_key = ""
# stt_model = "whisper-1"

# Knowledge source ingest pipeline.
# Each [[ingest.sources]] entry is an independent source with its own schedule and caps.
# Types: "gmail" (via GWS MCP), "file" (local directory), "notion" (via Notion MCP).

# Gmail source (requires GWS MCP server with Gmail-enabled accounts).
# [[ingest.sources]]
# name = "gmail"
# type = "gmail"
# enabled = true
# interval_minutes = 15
# backfill_days = 30
# trust_level = "untrusted"          # blocks preference/commitment extraction
# extraction = "llm"                 # "llm", "passthrough", or "hybrid"
# max_daily_observations = 100
# max_daily_llm_calls = 200
# min_importance = 3
# [ingest.sources.prefilter]
# labels = ["INBOX"]
# skip_senders = ["noreply@", "no-reply@", "notifications@", "mailer-daemon@"]

# Obsidian vault (mount directory into Docker as read-only volume).
# docker-compose: volumes: ["~/.obsidian-vault:/data/obsidian-vault:ro"]
# [[ingest.sources]]
# name = "obsidian"
# type = "file"
# enabled = true
# interval_minutes = 60
# trust_level = "trusted"            # all observation types allowed
# extraction = "hybrid"              # passthrough for YAML front matter, LLM fallback
# max_daily_observations = 200
# max_daily_llm_calls = 300
# min_importance = 3
# root_dir = "/data/obsidian-vault"
# patterns = ["*.md"]
# [ingest.sources.prefilter]
# include_paths = ["daily/", "projects/", "references/"]
# exclude_paths = [".obsidian/", ".trash/", "templates/"]

# Notion workspace (requires notion MCP server).
# [[ingest.sources]]
# name = "notion"
# type = "notion"
# enabled = false
# interval_minutes = 30
# trust_level = "trusted"
# extraction = "llm"
# max_daily_observations = 150
# max_daily_llm_calls = 250
# min_importance = 3

# DEPRECATED: [email_ingest] still works but auto-migrates to [[ingest.sources]].
# Prefer the new format above.
# [email_ingest]
# enabled = false
# interval_minutes = 15
# backfill_days = 30
# max_daily_observations = 100
# max_daily_llm_calls = 200
# min_importance = 3
# labels = ["INBOX"]
# skip_senders = ["noreply@", "no-reply@", "notifications@", "mailer-daemon@"]

# Agent personality. Loads a markdown file to replace the default "helpful personal assistant" persona.
# The file defines how the bot speaks, its character, language preferences, and behavioral rules.
# Note: cron/scheduled tasks use a separate fixed prompt, not this personality.
# [personality]
# file = "/data/personality.md"                # Absolute path. Max 20KB. UTF-8 only.

# Self-update configuration. Requires the curlycatclaw-updater sidecar container.
# Set UPDATER_SECRET in .env (next to docker-compose.yml) for authentication.
# [update]
# enabled = false                              # Enable /update, /status, /rollback Telegram commands
# updater_url = "http://curlycatclaw-updater:8081"  # Sidecar API URL (internal Docker network)
# auto_update = false                          # Opt-in automatic updates
# schedule = "0 3 * * 0"                       # Auto-update schedule (weekly Sunday 3am, cron format)

# Encrypted MCP credentials: set CURLYCATCLAW_MASTER_KEY env var (64 hex chars).
